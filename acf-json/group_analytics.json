            "label": "GTM Code",
            "name": "gtm_code",
            "type": "text",
            "instructions": "Enter your GTM container ID (e.g. GTM-XXXXXXX). GTM loads on every page and includes Google Consent Mode v2 support — on a visitor's first session, analytics and ad storage are blocked by default. When the visitor accepts cookies, consent is updated immediately via gtag() so GA4 and other GTM tags fire in the same session. On return visits, consent is read from the cookie server-side and set correctly before GTM initialises.",
            "required": 0,
            "conditional_logic": [
                [
                    {
                        "field": "field_gtm_enabled",
                        "operator": "==",
                        "value": "1"
                    }
                ]
