/* --------------------------------------------------- */
/* Variables */
/* --------------------------------------------------- */

@layer base {
    :root {
        /* --------------------------------------------------- */
        /* Spacing */
        /* --------------------------------------------------- */
        /* space(px) → rem, spaceFluid(min, max) → responsive calc() */

        --container-padding: 16px; /* Default inline padding for the page */
        --space-base: rem(16); /* Default vertical spacing between text elements */

        /* Default vertical spacing between larger components and blocks */
        --space-layout: space(32);
        --flow-space: var(--space-layout);

        @media (width >= theme("screens.sm")) {
            --container-padding: rem(30);
            --space-layout: space(64);
        }

        /* --------------------------------------------------- */
        /* Widths */
        /* --------------------------------------------------- */
        --width-fluid-container: calc(100% - (var(--container-padding) * 2));

        --width-fluid-2xs: min(var(--container-2xs), var(--width-fluid-container));
        --width-fluid-xs: min(var(--container-xs), var(--width-fluid-container));
        --width-fluid-sm: min(var(--container-sm), var(--width-fluid-container));
        --width-fluid-md: min(var(--container-md), var(--width-fluid-container));
        --width-fluid-lg: min(var(--container-lg), var(--width-fluid-container));

        /* --------------------------------------------------- */
        /* Base */
        /* --------------------------------------------------- */
        --site--scroll-padding-top: var(--site-header--bottom);

        /* --------------------------------------------------- */
        /* Border */
        /* --------------------------------------------------- */
        --base--border: 2px solid var(--color-brand-1);

        /* --------------------------------------------------- */
        /* Focus */
        /* --------------------------------------------------- */
        --focus--color: var(--color-brand-1);
        --base--focus-offset: 5px;
        --base--focus-width: 3px;

        /* --------------------------------------------------- */
        /* Box Shadow */
        /* --------------------------------------------------- */
        --base--shadow: 0 3px 9px hsla(var(--color-brand-1--hsl), 0.15);
        --base--shadow--hover: 0 3px 20px 3px hsla(var(--color-brand-1--hsl), 0.15);

        /* --------------------------------------------------- */
        /* Grids */
        /* --------------------------------------------------- */
        --col-gap: spaceFluid(8, 12);
        --row-gap: var(--col-gap);
        --cols: 1;
        --col-min-width: rem(300);

        @media (width >= theme("screens.md")) {
            --cols: 2;
        }

        @media (width >= theme("screens.lg")) {
            --cols: 4;
        }

        /* --------------------------------------------------- */
        /* Horizontal rule */
        /* --------------------------------------------------- */
        --hr--color: var(--color-brand-1);
        --hr--thickness: 2px;

        /* --------------------------------------------------- */
        /* Rounded corners - default rounding on blocks */
        /* --------------------------------------------------- */
        --rounded-border-radius: var(--radius--lg);
        --rounded-overflow: hidden;

        /* --------------------------------------------------- */
        /* Typography */
        /* --------------------------------------------------- */
        --heading--max-width: 17em;
        --heading--margin-top: 1lh;
        --heading--margin-bottom: var(--space-base);

        /* Fluid typography breakpoints */
        --fluid-min-width: strip-unit(theme("screens.fluid-min"));
        --fluid-max-width: strip-unit(theme("screens.fluid-max"));
        --fluid-screen: 100vw;
        --fluid-bp: calc(
            (var(--fluid-screen) - var(--fluid-min-width) / 16 * 1rem) /
            (var(--fluid-max-width) - var(--fluid-min-width))
        );

        @media (min-width: theme("screens.fluid-max")) {
            --fluid-screen: calc(var(--fluid-max-width) * 1px);
        }

        /* --------------------------------------------------- */
        /* General */
        /* --------------------------------------------------- */
        --underline-offset: 10%;

        /* --------------------------------------------------- */
        /* Links */
        /* --------------------------------------------------- */
        --link--color: var(--color-brand-1);
        --link--color-hover: var(--color-brand-1);
        --link--text-decoration: underline;
        --link--text-decoration--hover: underline;

        /* --------------------------------------------------- */
        /* Lists */
        /* --------------------------------------------------- */
        --list--item--spacing: calc(var(--space-base) / 2);
        --list--indent: 0px;
        --list--nested-indent: 1.5em;
        /* --list--marker-color: var(--color-brand-2); /* defaults to currentColor */

        @media (min-width: theme("screens.sm")) {
            --list--indent: 1.5em;
            --list--nested-indent: 2em;
        }
    }
}
