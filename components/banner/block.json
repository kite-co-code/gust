    "apiVersion": 3,
    "name": "acf/banner",
    "title": "Banner",
    "category": "theme-blocks",
    "icon": "align-center",
    "keywords": ["callout"],
    "align": "full",
    "acf": {
        "mode": "auto",
        "renderCallback": "Gust\\Components\\Banner::renderBlock"
